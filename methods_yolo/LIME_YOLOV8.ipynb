        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Example data for the confusion matrix\n",
        "cm_data = np.array([[0.97, 0.04, 0, 0.33],\n",
        "                    [0.01, 0.94, 0, 0.22],\n",
        "                    [0, 0, 0.91, 0.44],\n",
        "                    [0.02, 0.02, 0.09, 0]], dtype=float)\n",
        "\n",
        "# Define color map\n",
        "custom_color = (151/255, 193/255, 57/255)\n",
        "cmap = sns.light_palette(custom_color, as_cmap=True)\n",
        "\n",
        "plt.figure(figsize=(8, 6))\n",
        "sns.heatmap(cm_data, annot=True, fmt='.2f', cmap=cmap, cbar=False,\n",
        "            xticklabels=['Fully Tight Screw', 'Loose Screw', 'Missing Screw', 'Background'],\n",
        "            yticklabels=['Fully Tight Screw', 'Loose Screw', 'Missing Screw', 'Background'])\n",
        "cb = plt.colorbar(plt.cm.ScalarMappable(cmap=cmap))\n",
        "cb.set_label('Confusion Matrix Values')\n",
        "\n",
        "plt.xlabel('True Label')\n",
        "plt.ylabel('Predicted Label')\n",
        "plt.title('Confusion Matrix Normalised')\n",
        "plt.show()\n"
      ]
